<ui:FluentWindow x:Class="OneVolume.App.AppPickerWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Add app rule" Width="440" Height="520"
                 WindowStartupLocation="CenterOwner"
                 WindowCornerPreference="Round"
                 ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">
  <Grid Margin="16,42,16,14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Text="Pick an app — running or not. The rule applies whenever it plays audio."
               FontSize="12.5" Foreground="{StaticResource Brush.Muted}" TextWrapping="Wrap"/>

    <ui:TextBox x:Name="SearchBox" Grid.Row="1" Margin="0,10,0,8"
                PlaceholderText="Search installed apps… (or type a process name)"
                TextChanged="OnSearchChanged"/>

    <ListBox x:Name="AppList" Grid.Row="2" BorderThickness="0" Background="Transparent"
             MouseDoubleClick="OnListDoubleClick">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <StackPanel Margin="4,3">
            <TextBlock Text="{Binding DisplayName}"/>
            <TextBlock Text="{Binding ProcessName}" FontSize="11"
                       Foreground="{StaticResource Brush.Muted}"/>
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <Grid Grid.Row="3" Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock x:Name="CountText" VerticalAlignment="Center" FontSize="12"
                 Foreground="{StaticResource Brush.Muted}"/>
      <ui:Button Grid.Column="1" Content="Cancel" Appearance="Transparent" Margin="0,0,8,0"
                 Click="OnCancel"/>
      <ui:Button Grid.Column="2" Content="Add rule" Appearance="Primary" Click="OnAdd"/>
    </Grid>
  </Grid>
</ui:FluentWindow>
